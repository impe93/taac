# macOS code-signing / notarization credentials for `pnpm build:mac`.
# Copy to `.env` and fill in your values. NEVER commit the real `.env`.
#
# electron-builder does not auto-load this file — export the vars before building:
#   set -a && source .env && set +a && pnpm build:mac
#
# The "Developer ID Application" certificate must be installed in your login
# keychain (electron-builder auto-detects the signing identity from it).

# Apple ID email used for notarization.
APPLE_ID=you@example.com

# App-specific password generated at https://appleid.apple.com (Sign-In & Security
# → App-Specific Passwords). NOT your normal Apple ID password.
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Your 10-character Apple Developer Team ID (Membership page in the developer portal).
APPLE_TEAM_ID=ABCDE12345

# Optional: pin electron-builder's signing identity if you have several certs.
# IMPORTANT: no "Developer ID Application:" prefix — electron-builder picks the
# right cert TYPE automatically, so give only the common name + team.
# CSC_NAME=Your Name (ABCDE12345)
#
# The python-runtime deep-signing (scripts/afterPack.mjs) does NOT use CSC_NAME:
# it resolves the Developer ID Application cert by its SHA-1 hash automatically
# (unambiguous even if an Apple Development cert shares the same name). Override
# only if needed: TAAC_SIGN_IDENTITY=<40-char-sha1-hash>.
